# Environment Configuration for AgentVault

# Casper Network Configuration
CASPER_NETWORK=testnet
CASPER_NODE_URL=https://testnet-api.casper.network
CASPER_RPC_URL=https://testnet-rpc.casper.network

# MCP Server Configuration
MCP_SERVER_URL=http://localhost:8080/mcp

# Agent Configuration
YIELD_THRESHOLD_APR=15.0
RISK_THRESHOLD=70.0
KYC_EXPIRY_DAYS=365

# x402 Micropayment Settings
X402_ENABLED=true
MAX_GAS_PRICE=100

# Smart Contract Addresses (Testnet - to be updated after deployment)
PORTFOLIO_MANAGER_CONTRACT=casper-testnet-contract-pending
RWA_REGISTRY_CONTRACT=casper-testnet-contract-pending
AGENT_REPUTATION_CONTRACT=casper-testnet-contract-pending
COMPLIANCE_CONTRACT=casper-testnet-contract-pending

# Wallet Configuration (Use secure wallet management in production)
WALLET_ADDRESS=your-casper-wallet-address
# Never commit private keys to version control!

# API Keys for External Services
COINGECKO_API_KEY=
NEWSAPI_API_KEY=
ALPHAVANTAGE_API_KEY=

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=agentvault.log

# Monitoring and Metrics
ENABLE_METRICS=true
METRICS_PORT=9090
