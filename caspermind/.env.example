# Environment Variables for CasperMind Agents

# Casper Network Configuration
CASPER_RPC_URL=https://testnet.casper.network/rpc
CASPER_CHAIN_NAME=casper-testnet

# Oracle Agent Configuration
ORACLE_AGENT_PRIVATE_KEY=/path/to/oracle_secret_key.pem
ORACLE_AGENT_PAYMENT_ADDRESS=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
ORACLE_REGISTRY_CONTRACT_HASH=hash-will-be-filled-after-deployment

# Yield Agent Configuration
YIELD_AGENT_PRIVATE_KEY=/path/to/yield_secret_key.pem
ORACLE_AGENT_ENDPOINT=http://localhost:8001/oracle
ORACLE_PAYMENT_ADDRESS=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Compliance Agent Configuration
COMPLIANCE_AGENT_PRIVATE_KEY=/path/to/compliance_secret_key.pem
COMPLIANCE_TOKEN_CONTRACT_HASH=hash-will-be-filled-after-deployment

# Governor Agent Configuration
GOVERNOR_AGENT_PRIVATE_KEY=/path/to/governor_secret_key.pem

# API Keys (Optional - Free tiers available)
COINGECKO_API_KEY=
OPENAI_API_KEY=sk-...

# x402 Configuration
X402_PRICE_PER_REQUEST=1000000
X402_PAYMENT_TOKEN=CSPR

# Agent Identity Contract
AGENT_IDENTITY_CONTRACT_HASH=hash-will-be-filled-after-deployment
